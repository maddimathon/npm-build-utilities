{
    "name": "@maddimathon/build-utilities",
    "version": "0.3.0-beta",

    "author": "Maddi Mathon (https://www.maddimathon.com/web)",
    "description": "Opinionated utilities for easy build systems in npm projects.",
    "keywords": [
        "javascript-build-utilities",
        "npm-package",
        "npm-package-typescript",
        "typescript-build-utilities"
    ],

    "homepage": "https://maddimathon.github.io/npm-build-utilities",
    "license": "MIT",
    
    "repository": {
        "type": "git",
        "url": "https://github.com/maddimathon/npm-build-utilities.git"
    },

    "config": {
        "title": "NPM Build Utilities",
        "paths": {
            "releases": "@releases",
            "snapshots": ".snapshots"
        }
    },

    "engines": {
        "node": ">=22"
    },

    "type": "module",

    "files": [
        "./dist/**/*",
        "./LICENSE.md",
        "./package-lock.json",
        "./package.json",
        "./README.md",
        "./tsconfig.base.json",
        "./tsconfig.scripts.json"
    ],

    "main": "./dist/js/index.js",
    "types": "./dist/js/index.d.ts",

    "bin": {
        "build-utils": "./dist/js/bin/index.js"
    },

    "exports": {

        ".": {
            "types": "./dist/js/index.d.ts",
            "default": "./dist/js/index.js"
        },

        "./bin": {
            "types": "./dist/js/bin/index.d.ts",
            "default": "./dist/js/bin/index.js"
        },

        "./internal": {
            "types": "./dist/js/lib/@internal.d.ts",
            "default": "./dist/js/lib/@internal.js"
        },
        
        "./package": "./package.json",
        "./package.json": "./package.json",
        
        "./tsconfig": "./tsconfig.base.json",
        "./tsconfig.json": "./tsconfig.base.json",

        "./tsconfig.scripts": "./tsconfig.scripts.json",
        "./tsconfig.scripts.json": "./tsconfig.scripts.json",

        "./types": "./dist/js/types/index.d.ts",
        "./types/*": [
            "./dist/js/types/*.d.ts",
            "./dist/js/types/*/index.d.ts",
            "./dist/js/types/*"
        ],

        "./*": {

            "types": [
                "./dist/js/*.d.ts",
                "./dist/js/*/index.d.ts"
            ],

            "default": [
                "./dist/js/*.js",
                "./dist/js/*/index.js",
                "./dist/js/*"
            ]
        }
    },

    "bugs": {
        "url": "https://github.com/maddimathon/npm-build-utilities/issues"
    },

    "scripts": {
        "unlink": "run-s unlink:*",
            "unlink:ts": "rm -rf node_modules/@maddimathon/utility-typescript || echo ''",
            "x-unlink:tsconfig": "rm -rf node_modules/@maddimathon/tsconfig/dist || echo ''",
            "x-unlink:compiler-typedoc": "rm -rf node_modules/@maddimathon/compiler-typedoc/dist || echo ''",
            "x-unlink:universal-types": "rm -rf node_modules/@maddimathon/universal-types/dist || echo ''",

        "link": "run-s link:*",
            "link:ts": "npm run unlink:ts && mkdir -p node_modules/@maddimathon/utility-typescript && cp -R -H -f -p ../utility-typescript/package.json ../utility-typescript/tsconfig.json ../utility-typescript/dist node_modules/@maddimathon/utility-typescript",
            "x-link:tsconfig": "npm run unlink:tsconfig && mkdir -p node_modules/@maddimathon/tsconfig && cp -R -H -f -p ../npm-base-utilities/packages/tsconfig/dist ../npm-base-utilities/packages/tsconfig/package.json node_modules/@maddimathon/tsconfig",
            "x-link:compiler-typedoc": "npm run unlink:compiler-typedoc && mkdir -p node_modules/@maddimathon/compiler-typedoc && cp -R -H -f -p ../npm-base-utilities/packages/@helpers/compiler-typedoc/dist ../npm-base-utilities/packages/@helpers/compiler-typedoc/package.json node_modules/@maddimathon/compiler-typedoc",
            "x-link:universal-types": "npm run unlink:universal-types && mkdir -p node_modules/@maddimathon/universal-types && cp -R -H -f -p ../npm-base-utilities/packages/@helpers/universal-types/dist ../npm-base-utilities/packages/@helpers/universal-types/package.json node_modules/@maddimathon/universal-types",

            
        "test-utils": "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts --config .scripts/build.config.ts",

        "rm": "rm -r dist docs || echo ''",

        "reset": "run-s rm reset:*",
            "reset:demo-complete":  "cd demos/complete && npm run reset",
            "reset:demo-no-config": "cd demos/no-config && npm run reset",

        "commit": "sh .scripts/commit.sh",
        
        "snap":     "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts snapshot --config .scripts/build.config.ts",
        "snapshot": "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts snapshot --config .scripts/build.config.ts",
       
        "compile": "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts compile --config .scripts/build.config.ts",
        
        "build":       "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts build --config .scripts/build.config.ts",
        "quick-build": "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts build --without minimize,prettify,readme,demo --config .scripts/build.config.ts",
        
        "doc": "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts document --config .scripts/build.config.ts",

        "test": "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts test --config .scripts/build.config.ts",
        
        
        "prewatch": "npm run --silent quick-build -- --starting",
        
        "watch": "run-p --silent watch:*",
            "watch:docs": "watch -p 'src/docs/**/*' -p 'README.md' -c 'npm run --silent quick-build -- --only document   --watchedWatcher \"watch:js\" --watchedChange --watchedFilename \"$FILENAME\" --watchedEvent \"$EVENT\"'",
            "watch:js":   "watch -p 'src/ts/**/*'                  -c 'npm run --silent quick-build -- --only-compile js --watchedWatcher \"watch:js\" --watchedChange --watchedFilename \"$FILENAME\" --watchedEvent \"$EVENT\"'",
        
        "prepackage": "npm run rm",
        "predryrun":  "npm run rm",
        "prerelease": "npm run rm",
        
        "package": "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts package --config .scripts/build.config.ts",
        
        "dryrun":  "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts release --dryrun --without-package snapshot,zip --config .scripts/build.config.ts",
        "release": "tsx --tsconfig .scripts/tsconfig.json src/ts/bin/index.ts release --config .scripts/build.config.ts"
    },
    
    "dependencies": {
        "@maddimathon/utility-typescript": "~2.0.0-beta.5",
        "@tsconfig/node20": "~20.1.9",
        "glob": "~13.0.6",
        "luxon": "^3.7.2",
        "minimist": "~1.2.8",
        "postcss": "^8.5.16",
        "postcss-preset-env": "^11.3.2",
        "prettier": "^3.9.4",
        "sass-embedded": "~1.95.0",
        "semver": "~7.8.5",
        "typedoc-plugin-inline-sources": "^1.3.0",
        "typedoc-plugin-mdn-links": "~5.1.1"
    },
    "devDependencies": {
        "@jest/globals": "^30.4.1",
        "@types/jest": "^30.0.0",
        "@types/luxon": "^3.7.1",
        "@types/minimist": "^1.2.5",
        "@types/node": "22.15.30",
        "@types/semver": "^7.7.1",
        "jest": "^30.4.2",
        "npm-run-all": "4.1.5",
        "tsx": "^4.20.6",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "watch-cli": "^0.2.3"
    },

    "peerDependencies": {
        "@jest/globals": "^30.4.1",
        "jest": "^30.4.2",
        "postcss": "^8.5.16",
        "postcss-preset-env": "^11.3.2",
        "sass-embedded": "~1.95.0",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3"
    },
    "peerDependenciesMeta": {
        "@jest/globals": {
            "optional": true
        },
        "jest": {
            "optional": true
        },
        "postcss": {
            "optional": true
        },
        "postcss-preset-env": {
            "optional": true
        },
        "sass-embedded": {
            "optional": true
        },
        "typedoc": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    },
    
    "browserslist": [
        "last 3 major versions",
        "> 0.5%",
        "not dead"
    ]
}